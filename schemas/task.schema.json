{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex PM Task",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "priority",
    "risk",
    "size",
    "area",
    "depends_on",
    "human_approval",
    "locked",
    "description",
    "files_hint",
    "acceptance",
    "verify",
    "blocked_rules"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "done",
        "failed",
        "blocked",
        "needs_approval",
        "needs_review",
        "locked"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "risk": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "size": {
      "enum": [
        "XS",
        "S",
        "M",
        "L",
        "XL"
      ]
    },
    "area": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_approval": {
      "type": "boolean"
    },
    "locked": {
      "type": "boolean"
    },
    "description": {
      "type": "string"
    },
    "files_hint": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verify": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0
    }
  }
}
